# EU-sovereign LLM (Primary)
MISTRAL_API_KEY=your_mistral_key
MISTRAL_MODEL_FAST=mistral-small-latest
MISTRAL_MODEL_DEEP=mistral-large-latest

# EU-sovereign LLM (Fallback - Scaleway Paris/Amsterdam)
SCALEWAY_SECRET_KEY=your_scaleway_key
SCALEWAY_INFERENCE_ENDPOINT=https://api.scaleway.ai/v1

# Database (run on Hetzner DE or OVHcloud FR for full EU sovereignty)
DATABASE_URL=postgresql+asyncpg://forensica:password@localhost:5432/forensica_db
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change_this_to_a_secure_random_64_char_string
ENCRYPTION_KEY=change_this_32_byte_key_here_xxx

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000"]

# Czech AML Act 253/2008
AML_THRESHOLD_EUR=15000
DATA_RETENTION_DAYS=730
